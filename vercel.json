{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "aanvraag.atk-wpbr.nl"
        }
      ],
      "destination": "https://atk-wpbr-tool-v2-0.onrender.com/:path*"
    },
    { "source": "/resize", "destination": "/resize/index.html" }
  ],
  "redirects": [
    {
      "source": "/aanvraag",
      "destination": "https://atk-wpbr-tool-v2-0.onrender.com/login",
      "permanent": false
    },
    {
      "source": "/aanvraag/",
      "destination": "https://atk-wpbr-tool-v2-0.onrender.com/login",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
