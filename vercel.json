{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/resize", "destination": "/resize/index.html" }
  ],
  "redirects": [
    {
      "source": "/aanvraag",
      "destination": "https://atk-wpbr-tool-v2-0.onrender.com/login",
      "permanent": false
    },
    {
      "source": "/aanvraag/",
      "destination": "https://atk-wpbr-tool-v2-0.onrender.com/login",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
